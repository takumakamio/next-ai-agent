{
  "name": "next-ai-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cc": "claude --dangerously-skip-permissions",
    "with-dev": "dotenv -e .env.local --",
    "dev": "docker compose up -d && bun with-dev next dev",
    "build": "bun next build",
    "start": "bun next start",
    "lint": "bunx biome check .",
    "clean": "rm -rf .next",
    "db:generate": "bunx drizzle-kit generate --config=./db/drizzle.config.ts",
    "db:migrate": "bun ./db/migrate.ts",
    "db:gnm": "bun db:generate && bun db:migrate",
    "db:seed": "NODE_ENV=development bun ./db/seed.ts --config=./db/drizzle.config.ts",
    "db:drop": "NODE_ENV=development bun ./db/drop.ts",
    "db:reset": "NODE_ENV=development bun ./db/drop.ts --config=./db/drizzle.config.ts && bun db:generate && bun db:migrate && bun db:seed"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.18",
    "@gltf-transform/core": "^4.1.4",
    "@google/genai": "^1.27.0",
    "@hono/zod-openapi": "^0.18.4",
    "@hookform/resolvers": "^4.1.0",
    "@pixiv/three-vrm": "^3.4.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@react-three/drei": "^10.0.8",
    "@react-three/fiber": "^9.5.0",
    "@scalar/hono-api-reference": "^0.5.172",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-table": "^8.21.2",
    "ai": "^4.3.19",
    "aws4fetch": "^1.0.20",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.39.2",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.6.20",
    "lodash": "^4.17.23",
    "lucide-react": "^0.483.0",
    "nanoid": "^5.1.0",
    "next": "16.1.6",
    "next-intl": "^4.0.2",
    "next-safe-action": "^7.10.4",
    "postgres": "^3.4.5",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.2",
    "sonner": "^1.7.4",
    "swr": "^2.3.2",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.176.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4",
    "@types/lodash": "^4.17.15",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.176.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.30.5",
    "postcss": "^8.5.1",
    "tailwind-variants": "^0.3.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "resolutions": {
    "markdown-it": "13.0.2"
  }
}
