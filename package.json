{
  "name": "next-ai-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cc": "claude --dangerously-skip-permissions",
    "with-dev": "dotenv -e .env.local --",
    "dev": "npm with-dev next dev",
    "build": "npm next build",
    "start": "npm next start",
    "lint": "npx biome check .",
    "clean": "rm -rf .next",
    "db:generate": "npx drizzle-kit generate --config=./db/drizzle.config.ts",
    "db:migrate": "npm ./db/migrate.ts",
    "db:gnm": "npm db:generate && npm db:migrate",
    "db:seed": "NODE_ENV=development npm ./db/seed.ts --config=./db/drizzle.config.ts",
    "db:drop": "NODE_ENV=development npm ./db/drop.ts",
    "db:reset": "NODE_ENV=development npm ./db/drop.ts --config=./db/drizzle.config.ts && npm db:generate && npm db:migrate && npm db:seed"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.1.4",
    "@google/genai": "^1.27.0",
    "@hono/zod-openapi": "^0.18.4",
    "@hookform/resolvers": "^4.1.0",
    "@pixiv/three-vrm": "^3.4.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@react-three/drei": "^10.0.8",
    "@react-three/fiber": "^9.5.0",
    "@scalar/hono-api-reference": "^0.5.172",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-table": "^8.21.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.2",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.6.20",
    "lucide-react": "^0.483.0",
    "nanoid": "^5.1.0",
    "next": "16.1.6",
    "postgres": "^3.4.5",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.176.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.176.0",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.30.5",
    "postcss": "^8.5.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
